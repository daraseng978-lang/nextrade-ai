# Alpaca paper-trading credentials (free — sign up at alpaca.markets)
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_here

# Alpaca market-data feed: "iex" is free; "sip" requires paid subscription
ALPACA_FEED=iex

# Server port (frontend REST provider points here)
PORT=3001

# How long to cache a snapshot server-side before refetching (ms)
CACHE_TTL_MS=4000

# TradersPost dispatch (optional — leave blank to disable order routing)
# Get this URL from TradersPost: Strategies → your strategy → Webhook URL
# Format: https://webhooks.traderspost.io/trading/webhook/<id>/<token>
TRADERSPOST_WEBHOOK_URL=

# Telegram notifications (optional — leave blank to disable)
# 1. Talk to @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot (tap its name, press "Start")
# 3. Get your chat_id: open https://api.telegram.org/bot<TOKEN>/getUpdates
#    after sending a message — look for "chat":{"id":<number>
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduled morning brief (requires Telegram configured)
# Set to "false" to disable. MORNING_BRIEF_CRON uses node-cron format:
# "0 30 7 * * 1-5" = every weekday at 7:30 AM (second minute hour day month dayOfWeek)
MORNING_BRIEF_ENABLED=true
MORNING_BRIEF_CRON=0 30 7 * * 1-5
