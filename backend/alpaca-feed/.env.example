# ── Alpaca ─────────────────────────────────────────────────────────────
# Paper-trading credentials (free — sign up at alpaca.markets)
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_here
# Market-data feed: "iex" is free; "sip" requires a paid subscription
ALPACA_FEED=iex

# ── Server ─────────────────────────────────────────────────────────────
PORT=3001
# How long to cache a snapshot server-side before refetching (ms)
CACHE_TTL_MS=4000

# ── Market data source ─────────────────────────────────────────────────
# "alpaca" uses Alpaca IEX for intraday + Twelve Data for daily bars (recommended)
# "yahoo" uses Yahoo Finance for everything (~15 min delayed, no API key needed)
MARKET_PROVIDER=alpaca

# ── Hybrid daily bars (prior H/L) ──────────────────────────────────────
# Fetches consolidated daily bars once per day so priorHigh/priorLow are accurate.
# Fallback chain: Yahoo Finance → Twelve Data → scaled Alpaca ETF bars.
HYBRID_YAHOO_DAILIES=true
# node-cron format — default: every weekday at 8:00 AM
HYBRID_YAHOO_DAILIES_CRON=0 0 8 * * 1-5

# ── Twelve Data fallback ───────────────────────────────────────────────
# Used when Yahoo Finance is rate-limited. Free tier = 800 req/day.
# Sign up at https://twelvedata.com and paste your key here.
# Leave blank to disable (system falls back to scaled Alpaca ETF bars).
TWELVEDATA_API_KEY=

# ── Cross-market context (VIX / DXY / 10-year yield) ──────────────────
# Requires a paid Alpaca subscription (SIP feed). Set to "false" on free tier.
CROSS_MARKET_ENABLED=false

# ── AI signals (Claude) ────────────────────────────────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Model to use for signal generation. Haiku is fastest and cheapest.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── TradersPost order routing (optional) ──────────────────────────────
# Leave blank to disable automated order dispatch.
# Get this URL from TradersPost: Strategies → your strategy → Webhook URL
TRADERSPOST_WEBHOOK_URL=

# ── Telegram notifications (optional) ─────────────────────────────────
# 1. Talk to @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot, then send it any message
# 3. Get your chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
#    look for "chat":{"id":<number>}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Scheduled morning brief (requires Telegram configured above)
MORNING_BRIEF_ENABLED=true
# node-cron format — default: every weekday at 7:30 AM
MORNING_BRIEF_CRON=0 30 7 * * 1-5
