# Alpaca paper-trading credentials (free — sign up at alpaca.markets)
APCA_API_KEY_ID=your_key_id_here
APCA_API_SECRET_KEY=your_secret_here

# Alpaca market-data feed: "iex" is free; "sip" requires paid subscription
ALPACA_FEED=iex

# Server port (frontend REST provider points here)
PORT=3001

# How long to cache a snapshot server-side before refetching (ms)
CACHE_TTL_MS=4000

# TradersPost dispatch (optional — leave blank to disable order routing)
# Get this URL from TradersPost: Strategies → your strategy → Webhook URL
# Format: https://webhooks.traderspost.io/trading/webhook/<id>/<token>
TRADERSPOST_WEBHOOK_URL=
